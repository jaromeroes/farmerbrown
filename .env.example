# Farmer Brown — required environment variables
# Copy this file to `.env` (gitignored) and fill in real values.
# Load via `export $(grep -v '^#' .env | xargs)` before running scripts,
# or source it in your shell profile. Never commit `.env`.

# VAPI — https://dashboard.vapi.ai/org/{ORG_ID}/api-keys
# Used by every script under scripts/ that talks to the VAPI API.
VAPI_KEY=

# Calforce backend (Builders Risk + GL + Calendly booking API)
# Passed as `agent_api_key` query param to farmerbrown-bi.calforce.pro endpoints.
# Used by scripts/fix-calendly-tools.js and embedded in VAPI tool configs.
CALFORCE_AGENT_KEY=
